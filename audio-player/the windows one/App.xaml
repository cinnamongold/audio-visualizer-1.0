             xmlns:local="clr-namespace:LiquidAudioPlayer"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MusicFlowBackground.xaml" />
                <ResourceDictionary Source="Styles/LiquidGlass.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
