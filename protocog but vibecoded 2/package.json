{
  "name": "blank-slate-bot",
  "version": "1.0.0",
  "private": true,
  "description": "A tiny hybrid chatbot that learns from conversations without an LLM.",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "train": "python trainer/train.py --data-dir server/data",
    "predict": "python trainer/infer.py --data-dir server/data --text \"hello there\"",
    "cli:train": "python trainer/cli.py train --data-dir server/data",
    "cli:predict": "python trainer/cli.py predict --data-dir server/data --text \"hello there\"",
    "cli:export": "python trainer/cli.py export --data-dir server/data"
  },
  "keywords": [
    "chatbot",
    "pytorch",
    "express",
    "memory",
    "no-llm"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  }
}
